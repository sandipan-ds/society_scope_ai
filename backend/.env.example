# Backend environment variables
# Copy this file to backend/.env and adjust values for your local machine.

# JWT settings (change for any non-local environment).
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: only for development; allows login with demo credentials when the
# users table is still using DEV_PASSWORD_HASH placeholders. Set to false in prod.
ALLOW_DEV_PASSWORD_PLACEHOLDERS=true

# App metadata.
APP_NAME=Society Scope AI
APP_VERSION=0.1.0
APP_ENV=local

# Resident data source (relative to repo root).
# This Excel workbook is the runtime source of truth for residents, charges, fines, and payments.
MEMBERS_DATA_FILE=data/members_data/Housing_Society_Charges_and_Fines_Template_108_Residents.xlsx

# App-managed metadata store (users, documents, ingestion jobs, audit logs).
APP_STATE_DIR=data/app_state

# Where uploaded documents are stored (relative to repo root).
UPLOAD_DIR=data/uploads

# Where vector embeddings are stored (relative to repo root).
CHROMA_DIR=data/chroma

# Where sample documents are stored (relative to repo root).
SAMPLE_DOCS_DIR=data/sample_docs

# Legacy database path (kept for reference; not used by the Excel-only runtime).
DATABASE_URL=sqlite:///database/society.db
