# Backend environment variables
# Copy this file to backend/.env and adjust values for your local machine.

# Database connection (relative to repo root).
# Use a file-backed SQLite DB for the MVP; switch to Postgres later if needed.
DATABASE_URL=sqlite:///database/society.db

# JWT settings (change for any non-local environment).
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: only for development; allows login with demo credentials when the
# users table is still using DEV_PASSWORD_HASH placeholders. Set to false in prod.
ALLOW_DEV_PASSWORD_PLACEHOLDERS=true

# App metadata.
APP_NAME=Society Scope AI
APP_VERSION=0.1.0
APP_ENV=local
